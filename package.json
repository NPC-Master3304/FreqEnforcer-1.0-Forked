{
  "name": "freqenforcer",
  "version": "2.0.0",
  "description": "Formant-preserving pitch correction for Sparta Remixers",
  "author": "Krasen",
  "license": "MIT",
  "main": "electron/main.js",
  "homepage": "https://github.com/composition-cassidy/FreqEnforcer",
  "scripts": {
    "dev": "concurrently -n py,vite,electron -c blue,green,yellow \"python server/main.py\" \"npx vite\" \"node -e \\\"setTimeout(()=>require('child_process').execSync('npx electron electron/main.js',{stdio:'inherit'}),3000)\\\"\"",
    "dev:vite": "npx vite",
    "dev:server": "python server/main.py",
    "dev:electron": "npx electron electron/main.js",
    "build": "npx vite build"
  },
  "dependencies": {
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "i18next": "^26.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.freqenforcer.app",
    "productName": "FreqEnforcer",
    "copyright": "Copyright © 2026 Krasen",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build-resources"
    }
  }
}
