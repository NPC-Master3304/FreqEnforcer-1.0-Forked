    "pitch_mode": {
      "praat_soft": {
        "label": "PSOLA (Praat) Soft",
        "info": "Natural + smooth retune using Praat overlap-add. Requires praat-parselmouth."
      },
      "world_soft": {
        "label": "WORLD Soft (Retune)",
        "info": "Smooth retune with amount/speed/vibrato controls (WORLD vocoder)."
      },
      "world_hard": {
        "label": "WORLD Hard (Flatten)",
        "info": "Hard snap to the target note for the most robotic/locked sound (WORLD vocoder)."
      },
      "world_vt": {
        "label": "WORLD VT (Vocal Tract)",
        "info": "WORLD vocoder with pitch-adaptive vocal tract modeling. Adjusts formant structure based on pitch change for natural-sounding results."
      },
      "world_hnm": {
        "label": "WORLD HNM (Harmonic)",
        "info": "Harmonic resynthesis with vocal tract modeling. Cleanest harmonics, best for large pitch shifts."
      },
      "sine_spectral": {
        "label": "Sinusoidal (Spectral)",
        "info": "Tracks and shifts individual harmonics with spectral envelope preservation. Best for clean tonal sources."
      },
      "stft_pitchshift": {
        "label": "STFT Spectral (Phase Vocoder)",
        "info": "STFT phase vocoder with cepstral formant preservation. Clean, natural-sounding pitch shift."
      },
      "group_world": "WORLD",
      "group_psola": "PSOLA",
      "group_experimental": "EXPERIMENTAL"
    },
    "stretch_method": {
      "audiotsm_wsola": {
        "label": "WSOLA",
        "info": "Crisp in quality and the best for general speech audio. Can sound robotic if over-done."
      },
      "audiotsm_ola": {
        "label": "OLA",
        "info": "Overlap-add time stretching. Simple and fast."
      },
      "audiotsm_phasevocoder": {
        "label": "Phase Vocoder",
        "info": "Smoother and more ideal under x2 stretching"
      },
      "rubberband_default_engine_faster": {
        "label": "Rubber Band (Faster)",
        "info": "Faster Rubber Band engine. Good balance of speed and quality."
      },
      "rubberband_default_engine_finer": {
        "label": "Rubber Band (Finer)",
        "info": "Baseline of any stretching method."
      },
      "rubberband_percussive_engine_finer": {
        "label": "Rubber Band Percussive",
        "info": "Deals with transients and artifact removal a lot better than Rubber Band Default."
      },
      "tdpsola": {
        "label": "TD-PSOLA",
        "info": "Fallback stretcher that works without audiotsm/rubberband (can be slower)."
      }
    },
